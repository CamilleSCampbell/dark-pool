# ── Chiaroscuro configuration ─────────────────────────────────────────────
# Copy to .env and fill in. Demo mode requires NOTHING — leave it all blank to run offline.

# "demo"  = fixtures only (no network)
# "live"  = pull real clusters/books from Polymarket public APIs (reads are keyless)
# "auto"  = try live, fall back to demo   (default)
CHIAROSCURO_MODE=auto

# Server
CHIAROSCURO_HOST=0.0.0.0
CHIAROSCURO_PORT=8420

# Batch auction window, seconds
BATCH_WINDOW_SECONDS=30

# Solver economics
SOLVER_FEE_BPS=8            # fee the solver charges on residual fills
IMPACT_LAMBDA=0.9           # λ risk-aversion coefficient in the quote model

# ── Polymarket (live mode) ────────────────────────────────────────────────
# Public data (Gamma + CLOB reads) needs no keys. These are only for:
#  (a) authenticated CLOB endpoints / higher rate limits
#  (b) the fallback router that executes on Polymarket's own book
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

# Polygon wallet (ONLY needed to execute real trades / on-chain settlement)
# ⚠ Use a dedicated hot wallet with limited funds. Never your main key.
POLYGON_PRIVATE_KEY=
POLYGON_FUNDER_ADDRESS=
POLYGON_RPC_URL=https://polygon-rpc.com

# ── Optional integrations ─────────────────────────────────────────────────
# Anthropic key if you wire the solver-agent explanations to Claude
ANTHROPIC_API_KEY=
