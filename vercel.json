{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "env": {
    "HEDGEHOG_MODE": "live"
  },
  "services": {
    "dark-pool": {
      "root": ".",
      "entrypoint": "app.py"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": {
        "type": "service",
        "service": "dark-pool"
      }
    }
  ]
}
